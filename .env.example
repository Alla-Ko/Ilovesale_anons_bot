# Скопіюйте у файл .env у корені проєкту (поруч із Announcement.csproj) і заповніть значення.

# PostgreSQL — рядок Npgsql (Railway: Host/Port/Database з Dashboard або з URI postgresql://...)
# Приклад Railway (один рядок, без зайвого тексту в значенні):
# ConnectionStrings__DefaultConnection=Host=xxxx.proxy.rlwy.net;Port=59157;Database=railway;Username=postgres;Password=ВАШ_ПАРОЛЬ;SSL Mode=Require;Trust Server Certificate=true

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=announcement;Username=postgres;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# Початковий адмін (створюється один раз при міграції, якщо користувача ще немає)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD

# ImgBB — https://api.imgbb.com/
ImgBB__ApiKey=YOUR_IMGBB_KEY
# Додаткові ключі для ротації (1 основний + 7 додаткових; пробує наступний при "Invalid API v1 key")
# ImgBB__ApiKeys__0=YOUR_IMGBB_KEY_1
# ImgBB__ApiKeys__1=YOUR_IMGBB_KEY_2
# ImgBB__ApiKeys__2=YOUR_IMGBB_KEY_3
# ImgBB__ApiKeys__3=YOUR_IMGBB_KEY_4
# ImgBB__ApiKeys__4=YOUR_IMGBB_KEY_5
# ImgBB__ApiKeys__5=YOUR_IMGBB_KEY_6
# ImgBB__ApiKeys__6=YOUR_IMGBB_KEY_7

# Відео — tmpfile.link (POST multipart, поле file)
TempClip__ApiBaseUrl=https://tmpfile.link

# Telegraph — токен з @telegraph (https://telegra.ph/api)
Telegraph__AccessToken=YOUR_TELEGRAPH_TOKEN

# Telegram Bot + канал (бот — адмін каналу)
Telegram__BotToken=YOUR_BOT_TOKEN
Telegram__ChannelId=@your_channel_or_numeric_id

# REST API для зовнішнього бота (заголовок X-Api-Key або Authorization: Bearer)
BotApi__ApiKey=YOUR_BOT_API_SECRET
# Id користувача з AspNetUsers (якщо бот не передає CreatorUserId у запиті)
BotApi__DefaultCreatorUserId=
